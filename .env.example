# Supabase (여러 기기·배포 시 필수 권장)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# SEO (배포 도메인·검색 노출)
VITE_SITE_URL=https://your-site.vercel.app
# 스테이징·미완성 사이트는 noindex: VITE_ALLOW_INDEXING=false
# VITE_ALLOW_INDEXING=false

# GA4 (선택)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXX

# 문의 API — Supabase 영속 rate limit·문의 보관 (서버 전용, Git에 넣지 마세요)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase 미연결 시 로컬 관리자 비밀번호
VITE_ADMIN_PASSWORD=your-secure-password

# 문의 폼 이메일 (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=bano112@naver.com
CONTACT_FROM_EMAIL=COUCHPOTATO <onboarding@resend.dev>

# 문의 폼 IP 제한 (선택, 기본: 60초 간격 + 시간당 5회)
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MIN=60
CONTACT_RATE_LIMIT_COOLDOWN_SEC=60
